# Cooperating Experts — environment configuration.
# Copy this file to ".env" and fill in your values. The .env file is loaded
# automatically by generate_llm_data.py (via python-dotenv) and is gitignored.

# OpenAI-compatible API base URL. Examples:
#   https://api.openai.com/v1        (OpenAI)
#   https://openrouter.ai/api/v1     (OpenRouter)
#   http://localhost:8000/v1         (local vLLM / llama.cpp / Ollama / LM Studio)
LLM_API_BASE=https://api.openai.com/v1

# Model name to use for data generation. Examples:
#   gpt-4o-mini              (OpenAI, cheap, high quality)
#   gpt-4o                   (OpenAI, expensive, highest quality)
#   openai/gpt-oss-20b:free  (OpenRouter free tier)
#   deepseek-coder-7b        (local vLLM / Ollama)
LLM_MODEL=gpt-4o-mini

# API key. For OpenAI: sk-...  For local servers: usually any non-empty string.
LLM_API_KEY=sk-your-key-here

# Optional: override the request timeout (seconds) for slow local servers.
# LLM_TIMEOUT=120
